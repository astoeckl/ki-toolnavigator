os":["EU-Datenverarbeitung","Open-Source-Modelle verfügbar","Sehr schnelle Inferenz","Faire Preise"],"cons":["Kleineres Ökosystem","Weniger Integrationen","Weniger multimodal"],"usecases":["EU-Compliance","Self-Hosting","Chat","Coding"],"launched":"2024-02-26","lastUpdated":"2026-04-08","post_id":{"title":"Le Chat — Übersicht","content":"$18","short_description":"Europäisches LLM aus Paris — schnell, offen, DSGVO-freundlich.","keywords":"Mistral AI,sprachmodelle"},"media_id":"https://cognotor.s3.eu-central-1.amazonaws.com/uploads/site_49/tool_mistral.png","screenshot_id":"https://cognotor.s3.eu-central-1.amazonaws.com/uploads/site_49/24ee40a7_mistral_screenshot.jpg","logo_id":"https://cognotor.s3.eu-central-1.amazonaws.com/uploads/site_49/c59688ac_mistral_logo.png","features":"- **Le Chat Pro** mit Zugriff auf Mistral Large und Codestral.\n- **Web-Suche und Code-Interpreter** für aktuelle Recherchen & Analysen.\n- **Open-Weights-Modelle** (Mixtral, Mistral 7B, Codestral) — selbst hostbar.\n- **EU-Datenresidenz** — Server in Frankreich, DPA Standard.\n- **Sehr hohe Inferenz-Geschwindigkeit** dank optimierter Serving-Stack.\n- **Mistral API** mit Function Calling, JSON-Mode, Embeddings.\n- **Canvas** für strukturiertes Arbeiten an längeren Texten.","pricing":"- **Free** — kostenlose Nutzung von Le Chat mit Standard-Modellen.\n- **Pro** · €14,99 / Monat — Mistral Large 2, Web-Suche, Code-Interpreter, Bildgenerierung.\n- **Team** · €24,99 / Nutzer / Monat — kollaborative Spaces, Admin-Tools.\n- **Enterprise** · auf Anfrage — On-Prem- oder Private-Cloud-Deployment.\n- **API (La Plateforme)** — Mistral Large 2 ab €2 / 1 M Input, €6 / 1 M Output.\n- **Open-Source** — Mixtral/Mistral 7B/Codestral kostenlos unter Apache 2.0 nutzbar.","website":"https://chat.mistral.ai","_updated_at":"2026-04-22T07:26:52.807635Z","_id":19892},"catName":"Sprachmodelle & Chat","related":[{"slug":"llama","name":"Llama","vendor":"Meta","category":"sprachmodelle","tagline":"Metas Open-Weights-Sprachmodelle — von 1B bis 405B Parametern, lokal lauffähig.","price":"Open Source · API über Drittanbieter ab $0.10 / 1 M Token","api":true,"dsgvo":"ja","origin":"USA","rating":4.5,"reviews":1980,"pros":["Vollständig Open Weights","Größenstufen für jeden Use-Case","Starker Reasoning-Score (Llama 3.3)","Kann lokal/on-prem laufen"],"cons":["Kein offizieller Chat-Client","Multimodalität noch begrenzt","Lizenz keine echte OSS (Llama Community License)"],"usecases":["Self-Hosting","Forschung","Embedded LLMs","RAG-Backends"],"launched":"2023-02-24","lastUpdated":"2026-04-09","post_id":{"title":"Llama — Übersicht","content":"$19","short_description":"Metas Open-Weights-Sprachmodelle — von 1B bis 405B Parametern, lokal lauffähig.","keywords":"Meta,sprachmodelle"},"logo_id":"https://cognotor.s3.eu-central-1.amazonaws.com/uploads/site_49/c4b25b57_llama_logo.png","website":"https://llama.com","features":"- **Llama 3.3 70B & 405B** — Spitzenleistung bei Reasoning & Code, frei verfügbar.\n- **Open Weights** unter Llama-Community-License (kommerziell nutzbar bis 700 M MAU).\n- **Llama Stack** — offizielles Ökosystem für Inference, Fine-Tuning, Agenten.\n- **Llama Guard** für Output-Sicherheit.\n- **Multimodale Varianten** (Llama 3.2 Vision) für Bildeingaben.\n- **Verfügbar über Hugging Face, Together AI, Groq, AWS Bedrock, Vertex AI.**","pricing":"- **Self-Hosted** — kostenlos, benötigt GPU-Hardware (z. B. A100, H100 für 70B-Modelle).\n- **Together AI** · ab $0.10 / 1 M Token (Llama 3.3 70B).\n- **Groq** · extrem schnelle Inferenz, ähnlich günstig.\n- **AWS Bedrock / Vertex AI** · pay-as-you-go, mit EU-Datenresidenz.\n- **Lizenz** kostenlos für die meisten kommerziellen Anwendungen.","screenshot_id":"https://cognotor.s3.eu-central-1.amazonaws.com/uploads/site_49/1f3f1eda_llama_screenshot.jpg","media_id":"https://cognotor.s3.eu-central-1.amazonaws.com/uploads/site_49/tool_llama.png","_updated_at":"2026-04-24T11:13:10.478855Z","_id":19946},{"slug":"cohere","name":"Cohere Command","vendor":"Cohere","category":"sprachmodelle","tagline":"Enterprise-LLM aus Toronto — RAG-first, mehrsprachig, mit nativer EU-Verfügbarkeit.","price":"API ab $0.50 / 1 M Token (Command R)","api":true,"dsgvo":"ja","origin":"CA / EU","rating":4.3,"reviews":460,"pros":["Klarer Enterprise-Fokus","Embed-Modell weltklasse","Verfügbar in EU-Cloud-Regionen","Mehrsprachigkeit (100+ Sprachen)"],"cons":["Kein eigener Chat-Client","Schwächer in reinen Conversational-Benchmarks","Branding für Endnutzer kaum bekannt"],"usecases":["RAG-Pipelines","Enterprise-Suche","Mehrsprachige Klassifikation","Reranking"],"launched":"2021-11-16","lastUpdated":"2026-04-04","post_id":{"title":"Cohere Command — Übersicht","content":"$1a","short_description":"Enterprise-LLM aus Toronto — RAG-first, mehrsprachig, mit nativer EU-Verfügbarkeit.","keywords":"Cohere,sprachmodelle"},"logo_id":"https://cognotor.s3.eu-central-1.amazonaws.com/uploads/site_49/d05eb339_cohere_logo.png","website":"https://cohere.com","features":"- **Command R / R+ / R7B** — drei Größen für jeden Latenz-/Kostenpunkt.\n- **Embed v3** — eines der stärksten multilingualen Embedding-Modelle.\n- **Rerank 3** — präzises Re-Ranking für RAG-Pipelines.\n- **Tool Use & Function Calling** mit nativer JSON-Mode-Unterstützung.\n- **Citations** als First-Class-Feature in der Antwort-API.\n- **Verfügbar auf AWS, Google Cloud, Azure, Oracle Cloud — auch in EU-Regionen.**","pricing":"- **Free** · 1.000 API-Calls/Monat zum Ausprobieren.\n- **Command R** · $0.50 / 1 M Input · $1.50 / 1 M Output Token.\n- **Command R+** · $2.50 / 1 M Input · $10.00 / 1 M Output (für Top-Performance).\n- **Command R7B** · $0.04 / 1 M Token (für Edge-/Mobile-Deployments).\n- **Enterprise / On-Prem** · individuell, mit DPA, EU-Datenresidenz und Single-Tenant-Optionen.","screenshot_id":"https://cognotor.s3.eu-central-1.amazonaws.com/uploads/site_49/503e1b82_cohere_screenshot.jpg","media_id":"https://cognotor.s3.eu-central-1.amazonaws.com/uploads/site_49/tool_cohere.png","_updated_at":"2026-04-24T11:12:46.618602Z","_id":19947},{"slug":"chatgpt","name":"ChatGPT","vendor":"OpenAI","category":"sprachmodelle","tagline":"Der bekannteste KI-Assistent für Dialog, Recherche und Textarbeit.","price":"Freemium — Plus $20/Mon.","api":true,"dsgvo":"bedingt","origin":"USA","rating":4.6,"reviews":2841,"pros":["Größtes Ökosystem","Multimodal (Bild, Stimme, Dateien)","Custom GPTs & Store","Breite API-Verfügbarkeit"],"cons":["Datenverarbeitung außerhalb EU","Kontext-Limit in Plus-Tarif","Halluziniert bei Nischenfragen"],"usecases":["Recherche","Entwurf","Code-Review","Übersetzung","Brainstorming"],"launched":"2022-11-30","lastUpdated":"2026-03-12","post_id":{"title":"ChatGPT — Übersicht","content":"$1b","short_description":"Der bekannteste KI-Assistent für Dialog, Recherche und Textarbeit.","keywords":"OpenAI,sprachmodelle"},"media_id":"https://cognotor.s3.eu-central-1.amazonaws.com/uploads/site_49/tool_chatgpt.png","screenshot_id":"https://cognotor.s3.eu-central-1.amazonaws.com/uploads/site_49/51a8b961_chatgpt_screenshot.jpg","logo_id":"https://cognotor.s3.eu-central-1.amazonaws.com/uploads/site_49/cf4ded9d_chatgpt_logo.png","features":"- **GPT-5 & GPT-5 mini** — die aktuellen Modelle des Anbieters mit deutlich verbesserter Reasoning-Qualität.\n- **Multimodale Eingabe**: Text, Bild, Dokumente, Sprache — alles im selben Chat.\n- **Custom GPTs & GPT-Store** — eigene Assistenten bauen, teilen oder aus dem Marktplatz installieren.\n- **DALL·E 3** für direkte Bildgenerierung im Chat, inkl. Variations-Workflow.\n- **Advanced Data Analysis** — Python-Code-Ausführung, CSV-/Excel-Auswertung, Charts.\n- **Memory** erinnert sich über Sessions hinweg an Präferenzen (opt-in).\n- **OpenAI-API** mit Function Calling, Assistants, Responses, Structured Outputs.","pricing":"- **Free** — Zugriff auf GPT-5 mit reduzierten Limits.\n- **Plus** · $20 / Monat — volle GPT-5-Nutzung, bevorzugte Verfügbarkeit, Image-Gen, Data Analysis.\n- **Pro** · $200 / Monat — unbegrenzt GPT-5, o3-pro, längere Antworten.\n- **Team** · ab $25 / Nutzer / Monat — gemeinsamer Workspace, erweiterte Admin-Kontrollen.\n- **Enterprise** · Preis auf Anfrage — SSO, DPA, EU-Datenresidenz, erweiterte Compliance.\n- **API** — Pay-as-you-go, aktuell GPT-5 ab $1,25 / 1 M Input-Token, $10 / 1 M Output.","website":"https://chatgpt.com","_updated_at":"2026-04-22T07:26:53.338119Z","_id":19889}],"overviewHtml":"$1c","featuresHtml":"<ul>\n<li><strong>Le Chat Pro</strong> mit Zugriff auf Mistral Large und Codestral.</li>\n<li><strong>Web-Suche und Code-Interpreter</strong> für aktuelle Recherchen &amp; Analysen.</li>\n<li><strong>Open-Weights-Modelle</strong> (Mixtral, Mistral 7B, Codestral) — selbst hostbar.</li>\n<li><strong>EU-Datenresidenz</strong> — Server in Frankreich, DPA Standard.</li>\n<li><strong>Sehr hohe Inferenz-Geschwindigkeit</strong> dank optimierter Serving-Stack.</li>\n<li><strong>Mistral API</strong> mit Function Calling, JSON-Mode, Embeddings.</li>\n<li><strong>Canvas</strong> für strukturiertes Arbeiten an längeren Texten.</li>\n</ul>\n","pricingHtml":"<ul>\n<li><strong>Free</strong> — kostenlose Nutzung von Le Chat mit Standard-Modellen.</li>\n<li><strong>Pro</strong> · €14,99 / Monat — Mistral Large 2, Web-Suche, Code-Interpreter, Bildgenerierung.</li>\n<li><strong>Team</strong> · €24,99 / Nutzer / Monat — kollaborative Spaces, Admin-Tools.</li>\n<li><strong>Enterprise</strong> · auf Anfrage — On-Prem- oder Private-Cloud-Deployment.</li>\n<li><strong>API (La Plateforme)</strong> — Mistral Large 2 ab €2 / 1 M Input, €6 / 1 M Output.</li>\n<li><strong>Open-Source</strong> — Mixtral/Mistral 7B/Codestral kostenlos unter Apache 2.0 nutzbar.</li>\n</ul>\n"}]]}],"$L1d"]}]]}]
