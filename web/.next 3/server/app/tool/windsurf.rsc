",null,{"children":[["$","h5",null,{"children":"Kategorien"}],["$","ul",null,{"children":[["$","li","sprachmodelle",{"children":["$","$L12",null,{"href":"/kategorie/sprachmodelle","children":"Sprachmodelle & Chat"}]}],["$","li","bildgenerierung",{"children":["$","$L12",null,{"href":"/kategorie/bildgenerierung","children":"Bildgenerierung"}]}],["$","li","video-audio",{"children":["$","$L12",null,{"href":"/kategorie/video-audio","children":"Video & Audio"}]}],["$","li","coding",{"children":["$","$L12",null,{"href":"/kategorie/coding","children":"Coding-Assistenten"}]}],["$","li","agenten",{"children":["$","$L12",null,{"href":"/kategorie/agenten","children":"Agenten & Automation"}]}]]}]]}],["$","div",null,{"children":[["$","h5",null,{"children":"Rechtliches"}],["$","ul",null,{"children":[["$","li",null,{"children":["$","$L12",null,{"href":"/impressum","children":"Impressum"}]}],["$","li",null,{"children":["$","$L12",null,{"href":"/impressum#datenschutz","children":"Datenschutz"}]}],["$","li",null,{"children":["$","a",null,{"href":"mailto:andreas@stoeckl.ai","children":"Kontakt"}]}]]}]]}]]}],["$","div",null,{"className":"site-footer-bottom","children":[["$","span",null,{"children":"© 2026 Dr. Andreas Stöckl — alle Rechte vorbehalten"}],["$","span",null,{"children":"www.ki-toolnavigator.com"}]]}]]}]
