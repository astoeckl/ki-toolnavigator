{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/artikel/layout,_N_T_/artikel/[slug]/layout,_N_T_/artikel/[slug]/page,_N_T_/artikel/prompt-engineering,cms:category,cms:article"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/artikel/$d$slug/__PAGE__",
    "/artikel/$d$slug",
    "/artikel",
    "/_index",
    "/_head"
  ]
}